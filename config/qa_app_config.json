{
  "app_name": "FastAPI Auth Service",
  "version": "1.0.0",
  "environment": "development",
  "debug": true,
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "database": {
    "url": "mysql://root:123456@localhost:3306/auth_db"
  },
  "jwt": {
    "secret_key": "dev-secret-key-change-in-production",
    "algorithm": "HS256",
    "access_token_expire_minutes": 30,
    "refresh_token_expire_days": 7
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0,
    "password": null,
    "enabled": true
  },
  "rate_limiting": {
    "enabled": true,
    "requests": 100,
    "window_seconds": 60
  },
  "cors": {
    "origins": [
      "http://localhost:3000",
      "http://localhost:8000"
    ]
  }
}
