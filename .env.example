# Application Settings
APP_NAME=Nursery Backend API
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=False

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL with asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/database
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/nursery_db
# For Render/Railway: Use the DATABASE_URL provided by the platform
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/nursery_db

# JWT Settings
JWT_SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS Settings (comma-separated list)
CORS_ORIGINS=["http://localhost:3000", "https://your-frontend-domain.com"]

# Admin Credentials (Auto-created on startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=webhook_secret_here

# Demo Mode (auto-approves all payments for testing)
# Set to false in production!
DEMO_MODE=true

# Gemini AI Chatbot (Optional)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Redis Cache (Optional - for performance optimization)
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=